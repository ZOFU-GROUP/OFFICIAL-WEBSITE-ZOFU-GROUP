<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ZOFU GROUP — THINK. BUILD. CONQUER.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #080600;
      --bg2:     #0d0900;
      --fg:      #fff8ee;
      --fg2:     #a8956e;
      --orange:  #f97316;
      --yellow:  #fbbf24;
      --fire:    #ff4d00;
      --card:    #110e00;
      --border:  #2a2000;
      --border2: #3d2f00;
      --glow-o:  rgba(249,115,22,0.22);
      --glow-y:  rgba(251,191,36,0.16);
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--fg);
      font-family: 'Space Grotesk', sans-serif;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── NOISE ── */
    body::before {
      content:''; position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity:.5;
    }

    /* ── CURSOR ── */
    .cursor {
      width:13px; height:13px; background:var(--orange);
      border-radius:50%; position:fixed; top:0; left:0;
      pointer-events:none; z-index:9999;
      transform:translate(-50%,-50%);
      transition:width .18s, height .18s;
      mix-blend-mode:screen;
    }
    .cursor-ring {
      width:36px; height:36px;
      border:1.5px solid rgba(249,115,22,.5);
      border-radius:50%; position:fixed; top:0; left:0;
      pointer-events:none; z-index:9998;
      transform:translate(-50%,-50%);
      transition:width .18s, height .18s;
    }

    /* ── BG GRID ── */
    .hero-grid {
      position:fixed; inset:0; z-index:0; pointer-events:none;
      background-image:
        linear-gradient(rgba(249,115,22,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(249,115,22,.035) 1px, transparent 1px);
      background-size:60px 60px;
    }

    /* ── ORBS ── */
    .orb { position:fixed; border-radius:50%; filter:blur(90px); pointer-events:none; z-index:0; }
    .orb1 {
      width:700px; height:700px;
      background:radial-gradient(circle, rgba(249,115,22,.13), transparent 70%);
      top:-200px; right:-150px;
      animation:float1 13s ease-in-out infinite;
    }
    .orb2 {
      width:450px; height:450px;
      background:radial-gradient(circle, rgba(251,191,36,.09), transparent 70%);
      bottom:5%; left:-100px;
      animation:float2 15s ease-in-out infinite;
    }
    .orb3 {
      width:320px; height:320px;
      background:radial-gradient(circle, rgba(255,77,0,.07), transparent 70%);
      top:45%; left:48%;
      animation:float3 11s ease-in-out infinite;
    }
    @keyframes float1{0%,100%{transform:translate(0,0)}50%{transform:translate(-28px,38px)}}
    @keyframes float2{0%,100%{transform:translate(0,0)}50%{transform:translate(28px,-28px)}}
    @keyframes float3{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,28px)}}

    /* ── NAV ── */
    nav {
      position:fixed; top:0; left:0; right:0; z-index:100;
      display:flex; align-items:center; justify-content:space-between;
      padding:1rem 2.5rem;
      background:rgba(8,6,0,0.88);
      backdrop-filter:blur(20px);
      border-bottom:1px solid var(--border);
    }
    .nav-logo {
      font-family:'Syne',sans-serif; font-weight:800; font-size:1.1rem;
      letter-spacing:.04em; color:var(--fg); text-decoration:none;
      display:flex; align-items:center; gap:.55rem;
    }
    /* SVG thunder logo in nav */
    .thunder-logo {
      width:28px; height:28px; flex-shrink:0;
    }
    .nav-links { display:flex; gap:2rem; list-style:none; }
    .nav-links a {
      color:var(--fg2); text-decoration:none; font-size:.88rem;
      font-weight:500; transition:color .2s;
    }
    .nav-links a:hover { color:var(--fg); }
    .nav-cta {
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      color:#000; padding:.5rem 1.3rem; border-radius:6px;
      font-weight:700; font-size:.85rem; text-decoration:none;
      box-shadow:0 0 18px rgba(249,115,22,.4);
      transition:box-shadow .2s, transform .2s;
    }
    .nav-cta:hover { box-shadow:0 0 30px rgba(249,115,22,.65); transform:translateY(-1px); }

    /* ── HERO ── */
    .hero {
      min-height:100vh;
      display:flex; flex-direction:column; justify-content:center;
      padding:8rem 2.5rem 4rem;
      max-width:1200px; margin:0 auto;
      position:relative; z-index:1;
    }

    /* Big background thunder SVG */
    .hero-thunder-bg {
      position:absolute; right:-60px; top:50%;
      transform:translateY(-50%);
      width:480px; height:480px; opacity:.055;
      pointer-events:none; z-index:0;
      animation:thunderpulse 3s ease-in-out infinite;
    }
    @keyframes thunderpulse{0%,100%{opacity:.055}50%{opacity:.085}}

    .hero-tag {
      display:inline-flex; align-items:center; gap:.5rem;
      font-size:.74rem; letter-spacing:.16em; color:var(--yellow);
      text-transform:uppercase; margin-bottom:2rem;
      padding:.35rem .9rem; border:1px solid rgba(251,191,36,.22);
      border-radius:999px; background:rgba(251,191,36,.06); width:fit-content;
      position:relative; z-index:1;
    }
    .blink {
      width:6px; height:6px; background:var(--orange);
      border-radius:50%; animation:blink 1.4s infinite;
      box-shadow:0 0 6px var(--orange);
    }
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

    .hero h1 {
      font-family:'Syne',sans-serif;
      font-size:clamp(3.2rem,8vw,6.8rem);
      font-weight:800; line-height:1.0;
      letter-spacing:-0.03em; margin-bottom:1.8rem;
      position:relative; z-index:1;
    }
    .hero h1 .line2 {
      background:linear-gradient(120deg, var(--orange) 0%, var(--yellow) 60%, #fff176 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      background-clip:text;
      filter:drop-shadow(0 0 28px rgba(249,115,22,.5));
    }
    .hero-sub {
      font-size:1.1rem; color:var(--fg2); max-width:500px;
      margin-bottom:3rem; line-height:1.78;
      position:relative; z-index:1;
    }
    .hero-btns { display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:4rem; position:relative; z-index:1; }
    .btn-primary {
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      color:#000; padding:.85rem 2rem; border-radius:8px;
      font-weight:700; text-decoration:none; font-size:.95rem;
      box-shadow:0 4px 24px rgba(249,115,22,.45);
      transition:transform .2s, box-shadow .2s;
    }
    .btn-primary:hover { transform:translateY(-2px); box-shadow:0 6px 36px rgba(249,115,22,.65); }
    .btn-outline {
      border:1px solid var(--border2); color:var(--fg);
      padding:.85rem 2rem; border-radius:8px;
      font-weight:600; text-decoration:none; font-size:.95rem;
      transition:border-color .2s, background .2s;
    }
    .btn-outline:hover { border-color:var(--orange); background:rgba(249,115,22,.07); }

    /* hero stats */
    .hero-stats {
      display:flex; gap:3rem; flex-wrap:wrap;
      border-top:1px solid var(--border);
      padding-top:2.5rem; position:relative; z-index:1;
    }
    .stat-item .num {
      font-family:'Syne',sans-serif; font-size:2.2rem; font-weight:800;
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      background-clip:text;
    }
    .stat-item .label { font-size:.8rem; color:var(--fg2); letter-spacing:.06em; margin-top:.1rem; }

    /* scroll indicator */
    .scroll-indicator {
      position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%);
      display:flex; flex-direction:column; align-items:center; gap:.5rem;
    }
    .scroll-line {
      width:1px; height:50px;
      background:linear-gradient(to bottom, transparent, var(--orange));
      animation:scrollpulse 2s ease-in-out infinite;
    }
    @keyframes scrollpulse{0%,100%{opacity:.3}50%{opacity:1}}
    .scroll-text { font-size:.68rem; letter-spacing:.15em; color:var(--fg2); text-transform:uppercase; }

    /* ── SECTIONS ── */
    section { padding:7rem 2.5rem; position:relative; z-index:1; }
    .container { max-width:1100px; margin:0 auto; }
    .section-eyebrow {
      display:inline-flex; align-items:center; gap:.5rem;
      font-size:.72rem; letter-spacing:.2em; color:var(--orange);
      text-transform:uppercase; margin-bottom:1.2rem;
    }
    .section-eyebrow::before {
      content:''; width:24px; height:1px;
      background:linear-gradient(90deg, var(--orange), var(--yellow)); display:block;
    }
    h2 {
      font-family:'Syne',sans-serif;
      font-size:clamp(1.9rem,4vw,3rem);
      font-weight:800; margin-bottom:1rem; line-height:1.15;
    }
    .section-sub { color:var(--fg2); max-width:540px; line-height:1.75; margin-bottom:3.5rem; }

    /* ── ABOUT ── */
    .about-layout { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
    .about-text p { color:var(--fg2); line-height:1.85; margin-bottom:1.2rem; }
    .about-text strong { color:var(--fg); }
    .about-est {
      display:inline-flex; align-items:center; gap:.6rem;
      margin-top:1rem; font-size:.82rem; color:var(--fg2);
      border:1px solid var(--border2); padding:.5rem 1rem; border-radius:6px;
    }
    .about-visual { position:relative; }
    .about-card-stack { position:relative; height:360px; }
    .acard {
      position:absolute; background:var(--card);
      border:1px solid var(--border2); border-radius:16px; padding:1.8rem;
      transition:transform .3s;
    }
    .acard:hover { transform:translateY(-4px); }
    .acard1 { width:220px; top:0; left:0; z-index:3; border-color:rgba(249,115,22,.3); }
    .acard2 { width:200px; top:80px; left:130px; z-index:2; border-color:rgba(251,191,36,.25); }
    .acard3 { width:180px; top:170px; left:60px; z-index:1; border-color:rgba(255,77,0,.2); }
    .acard-icon { font-size:1.6rem; margin-bottom:.75rem; }
    .acard-title { font-weight:700; font-size:.9rem; margin-bottom:.3rem; }
    .acard-sub { font-size:.75rem; color:var(--fg2); }
    .acard-glow {
      position:absolute; width:100%; height:100%;
      background:radial-gradient(circle at 30% 50%, rgba(249,115,22,.08), transparent 70%);
      border-radius:16px; top:0; left:0; pointer-events:none;
    }

    /* ── THUNDER ICON (reusable SVG inline) ── */
    /* used as big hero bg and in about cards */

    /* ── DIVISIONS ── */
    .divs-bg { background:var(--bg2); }
    .divisions-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.5rem;
    }
    .div-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:16px; padding:2.2rem;
      position:relative; overflow:hidden;
      transition:border-color .3s, transform .3s;
    }
    .div-card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:2px;
      background:linear-gradient(90deg, var(--orange), var(--yellow));
      opacity:0; transition:opacity .3s;
    }
    .div-card:hover { border-color:rgba(249,115,22,.4); transform:translateY(-4px); }
    .div-card:hover::before { opacity:1; }
    .div-card-glow {
      position:absolute; width:220px; height:220px;
      border-radius:50%; filter:blur(65px);
      top:-60px; right:-60px; pointer-events:none;
      opacity:0; transition:opacity .4s;
    }
    .div-card:hover .div-card-glow { opacity:1; }
    .glow-o  { background:rgba(249,115,22,.18); }
    .glow-y  { background:rgba(251,191,36,.14); }
    .glow-f  { background:rgba(255,77,0,.13); }
    .div-icon-wrap {
      width:52px; height:52px; border-radius:12px;
      display:flex; align-items:center; justify-content:center;
      font-size:1.4rem; margin-bottom:1.4rem;
    }
    .icon-o { background:rgba(249,115,22,.15); border:1px solid rgba(249,115,22,.3); }
    .icon-y { background:rgba(251,191,36,.12); border:1px solid rgba(251,191,36,.25); }
    .icon-f { background:rgba(255,77,0,.12);   border:1px solid rgba(255,77,0,.25); }
    /* thunder SVG icon inside divisions */
    .div-thunder {
      width:28px; height:28px;
    }
    .div-card h3 {
      font-family:'Syne',sans-serif;
      font-size:1.1rem; font-weight:800; margin-bottom:.2rem;
    }
    .div-role { font-size:.78rem; color:var(--orange); margin-bottom:1rem; letter-spacing:.04em; font-weight:600; }
    .div-card p { font-size:.9rem; color:var(--fg2); line-height:1.75; margin-bottom:1.5rem; }
    .tags { display:flex; flex-wrap:wrap; gap:.45rem; }
    .tag {
      font-size:.7rem; padding:.25rem .65rem;
      border:1px solid var(--border2); border-radius:999px;
      color:var(--fg2);
    }

    /* ── PROJECTS ── */
    .projects-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:1.5rem;
    }
    .proj-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:16px; overflow:hidden;
      text-decoration:none; color:var(--fg);
      display:flex; flex-direction:column;
      transition:border-color .3s, transform .3s, box-shadow .3s;
    }
    .proj-card:hover {
      border-color:rgba(249,115,22,.45);
      transform:translateY(-5px);
      box-shadow:0 20px 60px rgba(249,115,22,.14);
    }
    .proj-thumb {
      height:180px;
      display:flex; align-items:center; justify-content:center;
      font-size:3.5rem; position:relative; overflow:hidden;
    }
    .proj-thumb-1 { background:linear-gradient(135deg,#150a00,#2a1200); }
    .proj-thumb-2 { background:linear-gradient(135deg,#0d1200,#1a2200); }
    .proj-thumb::after {
      content:''; position:absolute; inset:0;
      background:linear-gradient(to bottom, transparent 40%, var(--card));
    }
    .proj-badge {
      position:absolute; top:1rem; left:1rem;
      background:rgba(249,115,22,.2); border:1px solid rgba(249,115,22,.45);
      color:var(--orange); font-size:.68rem; font-weight:700;
      padding:.2rem .6rem; border-radius:999px; letter-spacing:.06em; z-index:1;
    }
    .proj-body { padding:1.6rem; flex:1; display:flex; flex-direction:column; gap:.75rem; }
    .proj-card h3 { font-family:'Syne',sans-serif; font-size:1rem; font-weight:800; }
    .proj-tagline { font-size:.8rem; color:var(--yellow); font-weight:600; }
    .proj-card p { font-size:.87rem; color:var(--fg2); line-height:1.7; flex:1; }
    .proj-link {
      display:inline-flex; align-items:center; gap:.4rem;
      font-size:.82rem; color:var(--orange); font-weight:600;
      text-decoration:none; margin-top:.25rem; transition:gap .2s;
    }
    .proj-link:hover { gap:.7rem; }

    /* ── PROCESS ── */
    .process-track {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
      gap:0; position:relative; margin-top:3rem;
    }
    .process-track::before {
      content:''; position:absolute; top:28px; left:0; right:0; height:1px;
      background:linear-gradient(90deg, transparent, var(--border2) 10%, var(--border2) 90%, transparent);
    }
    .process-step { padding:0 1.5rem 2rem; text-align:center; }
    .step-num {
      width:56px; height:56px; border-radius:50%;
      border:1px solid var(--border2); background:var(--card);
      display:flex; align-items:center; justify-content:center;
      font-family:'Syne',sans-serif; font-weight:800; font-size:1rem;
      color:var(--orange); margin:0 auto 1.2rem;
      position:relative; z-index:1;
      box-shadow:0 0 0 4px var(--bg), 0 0 14px rgba(249,115,22,.2);
    }
    .process-step h4 { font-weight:700; font-size:.95rem; margin-bottom:.4rem; }
    .process-step p { font-size:.82rem; color:var(--fg2); line-height:1.65; }

    /* ── TEAM ── */
    .team-bg { background:var(--bg2); }
    .team-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.5rem;
    }
    .team-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:16px; padding:2.2rem; text-align:center;
      position:relative; overflow:hidden;
      transition:border-color .3s, transform .3s;
    }
    .team-card:hover { border-color:rgba(249,115,22,.35); transform:translateY(-4px); }
    .team-avatar {
      width:72px; height:72px; border-radius:50%;
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      display:flex; align-items:center; justify-content:center;
      font-family:'Syne',sans-serif; font-size:1.5rem; font-weight:800;
      color:#000; margin:0 auto 1.2rem;
      box-shadow:0 0 22px rgba(249,115,22,.4);
    }
    .team-badge {
      display:inline-block; font-size:.68rem; padding:.22rem .7rem;
      background:rgba(249,115,22,.12); border:1px solid rgba(249,115,22,.28);
      color:var(--orange); border-radius:4px; font-weight:700;
      margin-bottom:1rem; letter-spacing:.05em;
    }
    .team-card h3 { font-family:'Syne',sans-serif; font-size:1.05rem; font-weight:800; margin-bottom:.2rem; }
    .team-title { font-size:.78rem; color:var(--yellow); margin-bottom:.8rem; font-weight:600; }
    .team-card p { font-size:.86rem; color:var(--fg2); line-height:1.65; }
    .team-card-glow {
      position:absolute; width:160px; height:160px;
      border-radius:50%; filter:blur(55px);
      background:rgba(249,115,22,.1);
      bottom:-50px; right:-30px; pointer-events:none;
    }

    /* ── CONTACT ── */
    .contact-layout { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start; }
    .contact-info .sub { color:var(--fg2); line-height:1.8; margin-bottom:2rem; }
    .contact-email-wrap {
      display:flex; align-items:center; gap:.75rem;
      background:var(--card); border:1px solid var(--border2);
      border-radius:10px; padding:1rem 1.4rem; margin-bottom:1.2rem;
      text-decoration:none; color:var(--fg);
      transition:border-color .2s, transform .2s;
    }
    .contact-email-wrap:hover { border-color:var(--orange); transform:translateX(4px); }
    .email-icon {
      width:40px; height:40px; border-radius:8px;
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      display:flex; align-items:center; justify-content:center;
      font-size:1rem; flex-shrink:0; color:#000;
    }
    .email-label { font-size:.72rem; color:var(--fg2); }
    .email-addr { font-size:.9rem; font-weight:600; }
    .contact-note { font-size:.78rem; color:var(--fg2); margin-top:.75rem; }
    .contact-form {
      background:var(--card); border:1px solid var(--border2);
      border-radius:16px; padding:2.2rem;
    }
    .form-row { margin-bottom:1.2rem; }
    .form-row label { display:block; font-size:.8rem; color:var(--fg2); margin-bottom:.45rem; font-weight:600; }
    .form-row input, .form-row textarea, .form-row select {
      width:100%; background:var(--bg);
      border:1px solid var(--border2); border-radius:8px;
      padding:.75rem 1rem; color:var(--fg);
      font-family:'Space Grotesk',sans-serif; font-size:.9rem;
      outline:none; transition:border-color .2s;
    }
    .form-row input:focus, .form-row textarea:focus, .form-row select:focus {
      border-color:var(--orange);
    }
    .form-row textarea { resize:vertical; min-height:110px; }
    .form-row select option { background:var(--bg); }
    .form-submit {
      width:100%;
      background:linear-gradient(135deg, var(--orange), var(--yellow));
      color:#000; border:none; border-radius:8px;
      padding:.9rem; font-family:'Space Grotesk',sans-serif;
      font-size:.95rem; font-weight:700; cursor:pointer;
      box-shadow:0 4px 20px rgba(249,115,22,.45);
      transition:transform .2s, box-shadow .2s;
    }
    .form-submit:hover { transform:translateY(-2px); box-shadow:0 6px 30px rgba(249,115,22,.65); }
    .form-2col { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }

    /* ── FOOTER ── */
    footer {
      border-top:1px solid var(--border);
      padding:3rem 2.5rem 2rem;
      position:relative; z-index:1;
    }
    .footer-inner { max-width:1100px; margin:0 auto; display:flex; flex-direction:column; gap:2rem; }
    .footer-top {
      display:flex; justify-content:space-between; align-items:flex-start;
      flex-wrap:wrap; gap:2rem;
    }
    .footer-brand .logo {
      font-family:'Syne',sans-serif; font-weight:800; font-size:1.15rem; color:var(--fg);
      margin-bottom:.5rem; display:flex; align-items:center; gap:.5rem;
    }
    .footer-brand p { font-size:.82rem; color:var(--fg2); max-width:260px; line-height:1.7; }
    .footer-links { display:flex; gap:3rem; flex-wrap:wrap; }
